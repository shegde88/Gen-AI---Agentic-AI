# ── Nebius Token Factory ────────────────────────────────────────────────
# Used for BOTH embeddings (text-embedding-3-small) AND LLM generation.
# Nebius is OpenAI-compatible — the same key works for both model calls.
NEBIUS_API_KEY=...
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
NEBIUS_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── Pinecone ─────────────────────────────────────────────────────────────
# Free serverless tier is enough (100k vectors). Index is auto-created.
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=fifa-wc-2026

# ── Cohere ───────────────────────────────────────────────────────────────
# Used for the reranker (cross-encoder). Free trial key available at cohere.com.
# If left blank, the app falls back to hybrid retrieval without reranking.
COHERE_API_KEY=...
